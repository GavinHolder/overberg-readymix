# Local development — SQLite, DEBUG on
DJANGO_SETTINGS_MODULE=Overberg_Readymix.settings.local
DJANGO_SECRET_KEY=local-dev-secret-key-change-this
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# SQLite (default) — no DATABASE_URL needed for local
# Uncomment to use local Postgres instead:
# DATABASE_URL=postgres://overberg:overberg@localhost:5432/overberg_local
