# Staging — Postgres, DEBUG off, local Docker
DJANGO_SETTINGS_MODULE=Overberg_Readymix.settings.staging
DJANGO_SECRET_KEY=staging-secret-key-change-before-use
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,overberg.localhost

DATABASE_URL=postgres://overberg:overberg@db:5432/overberg_staging

POSTGRES_DB=overberg_staging
POSTGRES_USER=overberg
POSTGRES_PASSWORD=overberg
