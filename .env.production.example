# Production — copy to .env.production and fill in real values
# NEVER commit .env.production to git

DJANGO_SETTINGS_MODULE=Overberg_Readymix.settings.production
DJANGO_SECRET_KEY=REPLACE_WITH_STRONG_SECRET_KEY
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=overbergreadymix.co.za,www.overbergreadymix.co.za
DJANGO_DEFAULT_FROM_EMAIL=noreply@overbergreadymix.co.za

DATABASE_URL=postgres://overberg:REPLACE_PASSWORD@db:5432/overberg_production

POSTGRES_DB=overberg_production
POSTGRES_USER=overberg
POSTGRES_PASSWORD=REPLACE_PASSWORD

REDIS_URL=redis://redis:6379/1

# Email (Mailgun / SendGrid / etc.)
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_HOST_USER=REPLACE_EMAIL_USER
EMAIL_HOST_PASSWORD=REPLACE_EMAIL_PASSWORD

# Sentry (optional)
SENTRY_DSN=

# CORS
CORS_ALLOWED_ORIGINS=https://overbergreadymix.co.za,https://www.overbergreadymix.co.za

# Traefik routing
TRAEFIK_HOST=overbergreadymix.co.za
ACME_EMAIL=admin@overbergreadymix.co.za
